---
import { ChevronLeft, ChevronRight, MoreHorizontal } from "lucide-react";

interface Props {
  currentPage: number;
  totalPages?: number;
  buildUrl: (page: number) => string;
  class?: string;
}

const { currentPage, totalPages, buildUrl, class: className } = Astro.props;

function getPaginationItems() {
  const items: (number | "ellipsis")[] = [];
  if (!totalPages || totalPages <= 1) return items;

  if (totalPages <= 7) {
    for (let i = 1; i <= totalPages; i++) items.push(i);
  } else {
    if (currentPage <= 4) {
      for (let i = 1; i <= 5; i++) items.push(i);
      items.push("ellipsis");
      items.push(totalPages);
    } else if (currentPage >= totalPages - 3) {
      items.push(1);
      items.push("ellipsis");
      for (let i = totalPages - 4; i <= totalPages; i++) items.push(i);
    } else {
      items.push(1);
      items.push("ellipsis");
      items.push(currentPage - 1);
      items.push(currentPage);
      items.push(currentPage + 1);
      items.push("ellipsis");
      items.push(totalPages);
    }
  }
  return items;
}

const items = getPaginationItems();
const prevUrl = currentPage > 1 ? buildUrl(currentPage - 1) : undefined;
const nextUrl = (!totalPages || currentPage < totalPages) ? buildUrl(currentPage + 1) : undefined;
---

{(totalPages !== 1) && (
  <nav class:list={["flex items-center justify-between pt-12 pb-8", className]} aria-label="Phân trang">
    <a 
      href={prevUrl} 
      aria-disabled={!prevUrl} 
      class="inline-flex items-center gap-2 rounded-lg bg-transparent px-4 py-[10px] text-[14px] font-semibold tracking-[0.083em] text-snow ring-1 ring-inset ring-white/20 transition hover:bg-white/5 hover:ring-snow aria-disabled:pointer-events-none aria-disabled:opacity-40"
    >
      <ChevronLeft className="h-4 w-4" /> 
      <span class="hidden sm:inline">Trang trước</span>
      <span class="sm:hidden">Trước</span>
    </a>

    <div class="hidden sm:flex items-center gap-1 mx-4">
      {items.map((item) => {
        if (item === "ellipsis") {
          return (
            <div class="flex h-10 w-10 items-center justify-center text-iron-veil" aria-hidden="true">
              <MoreHorizontal className="h-4 w-4" />
            </div>
          );
        }
        
        const isCurrent = item === currentPage;
        return (
          <a 
            href={buildUrl(item)} 
            aria-current={isCurrent ? "page" : undefined} 
            class={`grid h-10 min-w-[40px] place-items-center rounded-lg px-2 text-[14px] font-semibold tracking-[0.083em] transition ${isCurrent ? "bg-signal-blue text-snow" : "bg-transparent text-ash-mist hover:bg-white/5 hover:text-snow"}`}
          >
            {item}
          </a>
        );
      })}
    </div>

    {totalPages ? (
      <div class="flex sm:hidden items-center justify-center text-snow text-[14px] font-semibold tracking-[0.083em] px-4">
        {currentPage} / {totalPages}
      </div>
    ) : (
      <div class="flex sm:hidden items-center justify-center text-snow text-[14px] font-semibold tracking-[0.083em] px-4">
        {currentPage}
      </div>
    )}

    <a 
      href={nextUrl} 
      aria-disabled={!nextUrl} 
      class="inline-flex items-center gap-2 rounded-lg bg-transparent px-4 py-[10px] text-[14px] font-semibold tracking-[0.083em] text-snow ring-1 ring-inset ring-white/20 transition hover:bg-white/5 hover:ring-snow aria-disabled:pointer-events-none aria-disabled:opacity-40"
    >
      <span class="hidden sm:inline">Trang sau</span>
      <span class="sm:hidden">Sau</span>
      <ChevronRight className="h-4 w-4" />
    </a>
  </nav>
)}
