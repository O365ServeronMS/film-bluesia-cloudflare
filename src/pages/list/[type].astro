---
export const prerender = true;
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import { ListIsland } from "@/components/ListIsland";
import { createReturnToPath } from "@/lib/navigation";

export async function getStaticPaths() {
  return [
    { params: { type: "phim-moi-cap-nhat" } },
    { params: { type: "phim-le" } },
    { params: { type: "phim-bo" } },
    { params: { type: "hoat-hinh" } },
    { params: { type: "tv-shows" } }
  ];
}

const type = Astro.params.type || "phim-le";
const returnTo = createReturnToPath(Astro.url.pathname, Astro.url.search);

const typeTitles: Record<string, string> = {
  "phim-moi-cap-nhat": "Phim mới cập nhật",
  "phim-le": "Phim lẻ",
  "phim-bo": "Phim bộ",
  "tv-shows": "TV Show",
  "hoat-hinh": "Hoạt hình"
};
const displayTitle = typeTitles[type] || "Danh sách phim";
---

<BaseLayout title={`${displayTitle} - Bluesia Cinema`}>
  <ListIsland client:load type={type} returnTo={returnTo} />
</BaseLayout>
