---
import { ChevronLeft, ChevronRight } from "lucide-react";
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import { MovieCard } from "@/components/MovieCard";
import { TopBar } from "@/components/TopBar";
import { createReturnToPath } from "@/lib/navigation";
import { getCategories, getCountries, getList } from "@/lib/ophim";
import type { SourceLabel } from "@/lib/types";

const type = Astro.params.type || "phim-le";
const page = Math.max(1, Number(Astro.url.searchParams.get("page") || "1"));
const quickCountries = [
  { label: "Âu Mỹ", slug: "au-my" },
  { label: "Hàn Quốc", slug: "han-quoc" }
] as const;
const quickCategories = [{ label: "Phim chiếu rạp", slug: "phim-chieu-rap" }] as const;
const countryFilterableTypes = new Set(["phim-le", "phim-bo", "tv-shows"]);
const categoryFilterableTypes = new Set(["phim-le"]);
const supportsCountryFilter = countryFilterableTypes.has(type);
const supportsCategoryFilter = categoryFilterableTypes.has(type);

function safeFilterSlug(value: string | null | undefined) {
  const slug = String(value || "").trim().toLowerCase();
  return /^[a-z0-9]+(?:-[a-z0-9]+)*$/.test(slug) ? slug : "";
}

function normalizeTaxonomy(items: SourceLabel[]) {
  return items.flatMap((item) => {
    const name = String(item?.name || "").trim();
    const slug = safeFilterSlug(item?.slug);
    return name && slug ? [{ name, slug }] : [];
  });
}

const requestedCountry = supportsCountryFilter ? safeFilterSlug(Astro.url.searchParams.get("country")) : "";
const requestedCategory = supportsCategoryFilter ? safeFilterSlug(Astro.url.searchParams.get("category")) : "";
const [data, countryPayload, categoryPayload] = await Promise.all([
  getList(type, page, 30, requestedCountry, requestedCategory),
  supportsCountryFilter ? getCountries() : Promise.resolve([]),
  supportsCategoryFilter ? getCategories() : Promise.resolve([])
]);
const countries = normalizeTaxonomy(countryPayload);
const categories = normalizeTaxonomy(categoryPayload);
const country = countries.some((item) => item.slug === requestedCountry) ? requestedCountry : "";
const category = categories.some((item) => item.slug === requestedCategory) ? requestedCategory : "";
const returnTo = createReturnToPath(Astro.url.pathname, Astro.url.search);
const currentPage = data.page || page;
const totalPages = data.totalPages;
const groupStart = Math.floor((Math.max(1, currentPage) - 1) / 10) * 10 + 1;
const groupEnd = totalPages ? Math.min(groupStart + 9, totalPages) : groupStart + 9;
const pageNumbers = Array.from({ length: Math.max(0, groupEnd - groupStart + 1) }, (_, index) => groupStart + index);
const activeFilters = { country, category };
const typeTitles: Record<string, string> = {
  "phim-le": "Phim lẻ",
  "phim-bo": "Phim bộ",
  "tv-shows": "TV Show",
  "hoat-hinh": "Hoạt hình"
};
const activeCountryName = countries.find((item) => item.slug === country)?.name;
const activeCategoryName = categories.find((item) => item.slug === category)?.name;
const displayTitle = [typeTitles[type] || data.title, activeCountryName, activeCategoryName].filter(Boolean).join(" · ");

function listHref(nextPage: number, filters = activeFilters) {
  const query = new URLSearchParams({ page: String(Math.max(1, nextPage)) });
  if (filters.country) query.set("country", filters.country);
  if (filters.category) query.set("category", filters.category);
  return `/list/${type}?${query.toString()}`;
}
---

<BaseLayout title={`${displayTitle} - Bluesia Cinema`}>
  <TopBar client:load />
  <section class="px-4 pt-5">
    <h1 class="text-heading-sm font-bold leading-heading-sm text-snow">{displayTitle}</h1>
  </section>

  {(supportsCountryFilter || supportsCategoryFilter) && (
    <section class="px-4 pt-3" aria-label="Lọc nhanh">
      <div class="flex gap-2 overflow-x-auto pb-1 no-scrollbar">
        <a href={listHref(1, { country: "", category: "" })} aria-current={!country && !category ? "true" : undefined} class={`whitespace-nowrap rounded-[4.5px] border px-3 py-1.5 text-caption font-bold tracking-caption transition-colors ${!country && !category ? "border-signal-blue bg-signal-blue text-snow" : "border-white/10 bg-smoke text-ash-mist hover:text-snow"}`}>Tất cả</a>
        {supportsCountryFilter && quickCountries.map((item) => (
          <a href={listHref(1, { ...activeFilters, country: item.slug })} aria-current={country === item.slug ? "true" : undefined} class={`whitespace-nowrap rounded-[4.5px] border px-3 py-1.5 text-caption font-bold tracking-caption transition-colors ${country === item.slug ? "border-signal-blue bg-signal-blue text-snow" : "border-white/10 bg-smoke text-ash-mist hover:text-snow"}`}>{item.label}</a>
        ))}
        {supportsCategoryFilter && quickCategories.map((item) => (
          <a href={listHref(1, { ...activeFilters, category: item.slug })} aria-current={category === item.slug ? "true" : undefined} class={`whitespace-nowrap rounded-[4.5px] border px-3 py-1.5 text-caption font-bold tracking-caption transition-colors ${category === item.slug ? "border-signal-blue bg-signal-blue text-snow" : "border-white/10 bg-smoke text-ash-mist hover:text-snow"}`}>{item.label}</a>
        ))}
      </div>
    </section>
  )}

  <section class="grid grid-cols-3 gap-3 px-4 pt-5 sm:grid-cols-4">
    {data.items.map((movie, index) => (
      <MovieCard movie={movie} compact headingLevel={2} priority={index < 4} navSourceKey={type} returnTo={returnTo} />
    ))}
  </section>

  <nav class="px-4 pt-12 pb-8" aria-label="Phân trang">
    <div class="flex items-center justify-between gap-3">
      <a href={listHref(Math.max(1, currentPage - 1))} aria-disabled={currentPage <= 1} class="inline-flex items-center gap-2 rounded-lg bg-transparent px-4 py-[10px] text-[14px] font-semibold tracking-[0.083em] text-snow ring-1 ring-inset ring-iron-veil transition hover:bg-white/5 hover:ring-snow aria-disabled:pointer-events-none aria-disabled:opacity-40">
        <ChevronLeft className="h-4 w-4" /> Trang trước
      </a>
      <a href={listHref(currentPage + 1)} aria-disabled={totalPages ? currentPage >= totalPages : false} class="inline-flex items-center gap-2 rounded-lg bg-transparent px-4 py-[10px] text-[14px] font-semibold tracking-[0.083em] text-snow ring-1 ring-inset ring-iron-veil transition hover:bg-white/5 hover:ring-snow aria-disabled:pointer-events-none aria-disabled:opacity-40">
        Trang sau <ChevronRight className="h-4 w-4" />
      </a>
    </div>
    <div class="mt-6 flex gap-2 overflow-x-auto pb-2 no-scrollbar">
      {pageNumbers.map((pageNumber) => (
        <a href={listHref(pageNumber)} aria-current={pageNumber === currentPage ? "page" : undefined} class={`grid h-10 min-w-[40px] place-items-center rounded-lg px-3 text-[14px] font-semibold tracking-[0.083em] transition ${pageNumber === currentPage ? "bg-signal-blue text-snow" : "bg-transparent text-snow ring-1 ring-inset ring-iron-veil hover:bg-white/5 hover:ring-snow"}`}>
          {pageNumber}
        </a>
      ))}
    </div>
  </nav>

  {(countries.length || categories.length) ? (
    <section class="mx-4 mt-8 border-t border-white/10 pb-8 pt-6" aria-labelledby="all-filter-tags">
      <div class="flex items-center justify-between gap-3">
        <h2 id="all-filter-tags" class="text-caption font-bold uppercase tracking-caption text-iron-veil">Khám phá theo thẻ</h2>
        {(country || category) && <a href={listHref(1, { country: "", category: "" })} class="text-caption font-bold text-glacier-beam hover:text-snow">Xóa bộ lọc</a>}
      </div>
      <div class="mt-3 flex flex-wrap gap-2">
        {countries.map((item) => (
          <a href={listHref(1, { ...activeFilters, country: item.slug })} aria-current={country === item.slug ? "true" : undefined} class={`rounded-[4.5px] border px-2.5 py-1.5 text-caption font-semibold transition-colors ${country === item.slug ? "border-signal-blue text-glacier-beam" : "border-white/10 text-iron-veil hover:border-white/20 hover:text-snow"}`}>{item.name}</a>
        ))}
        {categories.map((item) => (
          <a href={listHref(1, { ...activeFilters, category: item.slug })} aria-current={category === item.slug ? "true" : undefined} class={`rounded-[4.5px] border px-2.5 py-1.5 text-caption font-semibold transition-colors ${category === item.slug ? "border-signal-blue text-glacier-beam" : "border-white/10 text-iron-veil hover:border-white/20 hover:text-snow"}`}>{item.name}</a>
        ))}
      </div>
    </section>
  ) : null}
</BaseLayout>
