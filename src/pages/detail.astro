---
// Client-rendered detail shell. Cloudflare serves this asset for every
// /movie/<slug> path via public/_redirects (200 rewrite to /detail/, which keeps
// the /movie/<slug> URL). It lives OUTSIDE the /movie/ namespace so the rewrite
// destination can't re-match the /movie/* source rule (Cloudflare rejects such
// loops). MovieDetailIsland reads the slug from window.location.
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import { MovieDetailIsland } from "@/components/MovieDetailIsland";
---

<BaseLayout title="Bluesia Cinema" type="video.movie">
  <MovieDetailIsland client:load />
</BaseLayout>
