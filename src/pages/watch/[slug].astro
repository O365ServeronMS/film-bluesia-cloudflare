---
import { hrefWithReturnTo, navSourceFromSearchParams, returnToFromSearchParams } from "@/lib/navigation";

const slug = Astro.params.slug || "";
const params = new URLSearchParams(Astro.url.searchParams);
const returnTo = returnToFromSearchParams(params);
const navSourceKey = navSourceFromSearchParams(params);
params.set("play", "1");
params.delete("returnTo");
params.delete("from");
const query = params.toString();
const movieHref = hrefWithReturnTo(`/movie/${slug}${query ? `?${query}` : ""}#player`, returnTo, navSourceKey);

return Astro.redirect(movieHref, 302);
---
