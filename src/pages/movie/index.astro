---
// Static shell for /movie/<slug>. Cloudflare serves this file for every
// /movie/* path via public/_redirects (200 rewrite); MovieDetailIsland reads the
// slug from window.location and fetches detail data from catalog-api client-side.
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import { MovieDetailIsland } from "@/components/MovieDetailIsland";
---

<BaseLayout title="Bluesia Cinema" type="video.movie">
  <MovieDetailIsland client:load />
</BaseLayout>
