---
import { ArrowLeft, Calendar, Clock, Play, Star, Users } from "lucide-react";
import BaseLayout from "@/src/layouts/BaseLayout.astro";
import { MovieActions } from "@/components/LocalMovieActions";
import { episodeWatchKey } from "@/lib/episodes";
import { fallbackReturnToForSource, getBackHref, hrefWithReturnTo, inferNavSourceFromMovie, navSourceFromSearchParams, returnToFromSearchParams } from "@/lib/navigation";
import { displayEpisodeServerName, getMovie, movieDetailCachePolicy } from "@/lib/ophim";
import { getDisplayRating, stripHtml } from "@/lib/utils";

const slug = Astro.params.slug || "";
const movie = await getMovie(slug);
const movieCache = movieDetailCachePolicy(movie);
Astro.response.headers.set("X-Film-Bluesia-Movie-Cache-Class", movieCache.cacheClass);
const firstEp = movie.episodes[0]?.serverData[0];
const heroImage = movie.poster || movie.thumb;
const heroSigned = movie.posterSigned || movie.thumbSigned;
const posterImage = movie.poster || movie.thumb;
const posterSigned = movie.posterSigned || movie.thumbSigned;
const title = `Bluesia Cinema - ${movie.originName || movie.name}`;
const description = stripHtml(movie.content) || "Góc nhỏ của người đam mê phim";
const metaImage = movie.thumbSigned?.d || movie.posterSigned?.d || movie.thumb || movie.poster || "/icon-512.png";
const displayRating = getDisplayRating(movie);
const navSourceKey = navSourceFromSearchParams(Astro.url.searchParams) || inferNavSourceFromMovie(movie);
const returnTo = returnToFromSearchParams(Astro.url.searchParams) || fallbackReturnToForSource(navSourceKey);
const primaryWatchHref = hrefWithReturnTo(`/watch/${movie.slug}${firstEp ? `?ep=${encodeURIComponent(episodeWatchKey(firstEp, 0))}` : ""}`, returnTo, navSourceKey);
const backHref = getBackHref(Astro.url.searchParams, { source: navSourceKey, fallbackPath: "/" });
---

<BaseLayout title={title} description={description} image={metaImage} type="video.movie" navSourceFallback={navSourceKey}>
  <article>
    <section class="relative min-h-[560px] overflow-hidden">
      {heroImage && (
        <picture>
          <source media="(max-width: 767px)" srcset={heroSigned?.m || heroImage} />
          <source media="(min-width: 768px)" srcset={heroSigned?.d || heroImage} />
          <img
            src={heroSigned?.d || heroImage}
            alt={movie.name}
            class="absolute inset-0 h-full w-full object-cover opacity-60"
            fetchpriority="low"
            loading="lazy"
            decoding="async"
          />
        </picture>
      )}
      <div class="absolute inset-0 bg-gradient-to-b from-obsidian/30 via-obsidian/80 to-obsidian"></div>
      <div class="relative z-10 px-4 pb-8 pt-5">
        <a href={backHref} data-nav-back class="grid h-11 w-11 place-items-center rounded-lg bg-obsidian/50 text-snow">
          <ArrowLeft className="h-5 w-5" />
        </a>
        <div class="mt-10 flex gap-4">
          <div class="w-36 shrink-0 overflow-hidden rounded-3xl bg-zinc-900 shadow-2xl ring-1 ring-white/10">
            {posterImage && (
              <picture>
                <source media="(max-width: 767px)" srcset={posterSigned?.m || posterImage} />
                <source media="(min-width: 768px)" srcset={posterSigned?.d || posterImage} />
                <img
                  src={posterSigned?.d || posterImage}
                  alt={movie.name}
                  class="aspect-[2/3] h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                  data-movie-poster
                  data-fallback-src={posterSigned?.d || posterImage || undefined}
                  data-original-src={posterImage || undefined}
                  data-placeholder-src="/image-placeholder.svg"
                />
              </picture>
            )}
          </div>
          <div class="min-w-0 flex-1 pt-4">
            {displayRating && (
              <div class="mb-3 inline-flex items-center gap-1 rounded-[4.5px] bg-obsidian/80 px-2.5 py-1 text-[11px] font-bold uppercase tracking-[0.083em] text-snow">
                <Star className="h-3.5 w-3.5 fill-current text-snow" /> {displayRating.text}
              </div>
            )}
            <h1 class="text-heading font-bold leading-heading tracking-tight text-snow">{movie.name}</h1>
            <p class="mt-2 line-clamp-2 text-body text-ash-mist">{movie.originName}</p>
            <div class="mt-4 flex flex-wrap gap-2 text-caption font-semibold uppercase tracking-caption text-iron-veil">
              {movie.year && <span class="inline-flex items-center gap-1 rounded-[4.5px] bg-snow/5 px-2.5 py-1"><Calendar className="h-3.5 w-3.5" /> {movie.year}</span>}
              {movie.time && <span class="inline-flex items-center gap-1 rounded-[4.5px] bg-snow/5 px-2.5 py-1"><Clock className="h-3.5 w-3.5" /> {movie.time}</span>}
              {movie.episodeCurrent && <span class="rounded-[4.5px] bg-snow/5 px-2.5 py-1">{movie.episodeCurrent}</span>}
              {movie.quality && <span class="rounded-[4.5px] bg-smoke/80 px-2.5 py-1 text-snow">{movie.quality}</span>}
            </div>
          </div>
        </div>
        <div class="mt-6 grid gap-3">
          <a href={primaryWatchHref} class="inline-flex items-center justify-center gap-2 rounded-lg bg-signal-blue px-5 py-4 text-body font-bold text-snow transition-colors hover:bg-signal-blue/90">
            <Play className="h-5 w-5 fill-current" /> Xem phim
          </a>
          <MovieActions client:load movie={movie} />
        </div>
      </div>
    </section>

    <section class="px-4 pb-6">
      <div class="flex flex-wrap gap-2 text-caption font-semibold uppercase tracking-caption text-iron-veil">
        {movie.categoryList?.map((item) => <span class="rounded-[4.5px] bg-snow/5 px-3 py-1.5">{item.name}</span>)}
        {movie.countryList?.map((item) => <span class="rounded-[4.5px] bg-snow/5 px-3 py-1.5">{item.name}</span>)}
      </div>

      <h2 class="mt-8 text-heading-sm font-bold text-snow">Nội dung</h2>
      <p class="mt-3 text-body leading-body-lg text-ash-mist">{stripHtml(movie.content) || "Chưa có mô tả."}</p>

      {movie.actor?.length ? (
        <div class="mt-6 rounded-lg bg-smoke p-4">
          <h3 class="mb-3 inline-flex items-center gap-2 text-body font-bold text-snow"><Users className="h-4 w-4 text-signal-blue" /> Diễn viên</h3>
          <p class="text-body leading-body-lg text-ash-mist">{movie.actor.slice(0, 12).join(", ")}</p>
        </div>
      ) : null}

      {movie.episodes.length ? (
        <div class="mt-8">
          <h2 class="text-heading-sm font-bold text-snow">Tập phim</h2>
          {movie.episodes.map((server, serverIndex) => (
            <div class="mt-4 rounded-lg bg-smoke p-4">
              <h3 class="mb-3 text-body font-bold text-snow">{displayEpisodeServerName(server.serverName)}</h3>
              <div class="grid grid-cols-4 gap-2 sm:grid-cols-6">
                {server.serverData.map((ep, epIndex) => (
                  <a href={hrefWithReturnTo(`/watch/${movie.slug}?server=${serverIndex}&ep=${encodeURIComponent(episodeWatchKey(ep, epIndex))}`, returnTo, navSourceKey)} class="rounded-[4.5px] bg-obsidian px-3 py-2 text-center text-body font-bold text-snow transition-colors hover:bg-signal-blue">
                    {ep.name || epIndex + 1}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      ) : null}
    </section>
  </article>
</BaseLayout>
