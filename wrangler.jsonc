{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "blueflare",
  "compatibility_date": "2026-05-30",
  // Static-assets-only deployment — no Worker entry (`main`), no KV, no signing
  // secrets. All catalog data is served by the VPS catalog-api at
  // img.bluesia.net/api/*. /movie/* and /watch/* routing lives in public/_redirects.
  "assets": {
    "directory": "dist"
  },
  "routes": [
    {
      "pattern": "film.bluesia.net",
      "custom_domain": true
    }
  ]
}
