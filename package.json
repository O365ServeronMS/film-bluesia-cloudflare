{
  "name": "film",
  "version": "6.0.1",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "test:image-normalization": "node --no-warnings --experimental-strip-types scripts/test-image-normalization.mjs",
    "test:kv-write-resilience": "node --no-warnings --experimental-strip-types --import ./scripts/register-alias.mjs scripts/test-kv-write-resilience.mjs",
    "test:security-controls": "node --no-warnings --experimental-strip-types --import ./scripts/register-alias.mjs scripts/test-security-controls.mjs",
    "test:ophim-latest-order": "node --no-warnings --experimental-strip-types --import ./scripts/register-alias.mjs scripts/test-ophim-latest-order.mjs",
    "test:snapshot": "node --no-warnings --experimental-strip-types --import ./scripts/register-alias.mjs scripts/test-snapshot.mjs",
    "scan:image-hosts": "node --no-warnings --experimental-strip-types --import ./scripts/register-alias.mjs scripts/scan-ophim-image-hosts.mjs",
    "preview": "astro build && astro preview",
    "deploy": "astro build && wrangler deploy",
    "build:refresh": "wrangler deploy --dry-run --outdir dist-refresh -c wrangler-refresh.jsonc",
    "dry-run:refresh": "wrangler deploy --dry-run -c wrangler-refresh.jsonc",
    "deploy:refresh": "wrangler deploy -c wrangler-refresh.jsonc"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.0.0",
    "@astrojs/react": "^6.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.0",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.21.0",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "sharp": "^0.35.2",
    "wrangler": "latest"
  },
  "browserslist": [
    "Chrome >= 90",
    "Firefox >= 90",
    "Safari >= 14",
    "Edge >= 90",
    "not IE 11"
  ]
}
